# Despliegue Hostinger (Node, sin Docker): ver deploy/HOSTINGER-API-NODE.md
#
# MySQL (misma base que `web` si compartís entorno)
#
# Hostinger — MySQL remoto (panel "MySQL remoto": permitir host % o la IP del API):
# DATABASE_URL=mysql://USUARIO_MYSQL:TU_CLAVE@srv722.hstgr.io:3306/NOMBRE_BD
#
# Si la clave tiene @ # % etc., codificála en la URL (encodeURIComponent).
# Reemplazá CAMBIAR_HOST_MYSQL por el hostname o IP donde corre MySQL (contenedor `mysql`, IP del VPS, etc.).
DATABASE_URL=mysql://root:password@CAMBIAR_HOST_MYSQL:3306/mbarete_3d
# En local, `npm run dev` ejecuta `prisma migrate deploy` antes de arrancar (predev).
#
# Local con Docker: ver back/docs/LOCAL-MYSQL.md (puerto = el que mapea Docker, 3307 en compose de back/ o 3306 si tu stack usa 3306:3306)
# Ej.: DATABASE_URL=mysql://mbarete:mbarete_dev@127.0.0.1:3307/mbarete
#
# Parches SQL manuales para ejecutar en el servidor: back/scripts/sql/

# Secreto JWT (alinear con AUTH_SECRET de Next si compartís sesión).
# Obligatorio si NODE_ENV=production (p. ej. `npm start`). En local, `npm run dev` fuerza NODE_ENV=development;
# si tu Windows tiene NODE_ENV=production en variables de usuario, definí AUTH_SECRET aquí o usá siempre `npm run dev`.
AUTH_SECRET=cambiar-en-produccion-minimo-32-caracteres
# Opcional alias:
# JWT_SECRET=

# Sesión: segundos de vida del JWT (2592000 = 30 días)
JWT_EXPIRES_SEC=2592000

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Servidor
PORT=3056
NODE_ENV=development

# CORS: orígenes del front (coma-separados) o * (solo si sabés lo que implica)
# Ej.: https://tu-preprod.hostingersite.com,https://3dmbarete.com.py,https://www.3dmbarete.com.py
CORS_ORIGIN=

# URL pública de este API (sin barra final). Mismos archivos bajo /uploads. Alias: PUBLIC_BASE_URL si no definís PUBLIC_FILES_BASE_URL.
PUBLIC_FILES_BASE_URL=
# PUBLIC_BASE_URL=

# Cloudinary (recomendado para persistir imágenes entre despliegues)
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# Correo del dueño (contacto y checkout)
OWNER_EMAIL=tu@email.com

# Resend (opcional; sin clave solo se registra en consola)
RESEND_API_KEY=re_ZCPAijVA_JtKiMQ4bHKFFj2kovShYjaDQ
EMAIL_FROM=3D Mbarete <onboarding@resend.dev>

# Cron: expirar pedidos pendientes (mismo valor que CRON_SECRET en web)
CRON_SECRET=

# Docker: limpieza diaria de uploads huérfanos con supercronic + back/crontab (proceso aparte del API).
# Desactivar en el contenedor: ENABLE_UPLOAD_CLEANUP_CRON=0

# Seed de administrador (`npm run db:seed` o al arrancar el contenedor Docker tras migrar).
ADMIN_SEED_EMAIL=admin@3dmbarete.local
ADMIN_SEED_PASSWORD=admin1234
