# MySQL (misma base que `web` si compartís entorno)
#
# Local:
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/mbarete_3d
#
# Hostinger — MySQL remoto (panel "MySQL remoto": permitir host % o la IP del API):
# Usá el hostname del panel remoto (ej. srv722.hstgr.io), no el dominio del sitio.
# DATABASE_URL=mysql://USUARIO_MYSQL:TU_CLAVE@srv722.hstgr.io:3306/NOMBRE_BD
#
# Si la clave tiene @ # % etc., codificála en la URL (encodeURIComponent).
DATABASE_URL=mysql://root:password@127.0.0.1:3306/mbarete_3d

# Secreto JWT (alinear con AUTH_SECRET de Next si compartís sesión).
# Obligatorio si NODE_ENV=production (p. ej. `npm start`). En local, `npm run dev` fuerza NODE_ENV=development;
# si tu Windows tiene NODE_ENV=production en variables de usuario, definí AUTH_SECRET aquí o usá siempre `npm run dev`.
AUTH_SECRET=cambiar-en-produccion-minimo-32-caracteres
# Opcional alias:
# JWT_SECRET=

# Sesión: segundos de vida del JWT (2592000 = 30 días)
JWT_EXPIRES_SEC=2592000

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Servidor
PORT=3056
NODE_ENV=development

# CORS: orígenes del front (coma-separados) o * en desarrollo
# Incluir Vite (5173) y Next legacy (3000) si aplica
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# URL pública de esta API para enlaces de archivos subidos (opcional; por defecto http://localhost:PORT)
PUBLIC_FILES_BASE_URL=http://localhost:3056

# Correo del dueño (contacto y checkout)
OWNER_EMAIL=tu@email.com

# Resend (opcional; sin clave solo se registra en consola)
RESEND_API_KEY=
EMAIL_FROM=3D Mbarete <onboarding@resend.dev>

# Cron: expirar pedidos pendientes (mismo valor que CRON_SECRET en web)
CRON_SECRET=

# Seed de administrador (`npm run db:seed` o al arrancar el contenedor Docker tras migrar).
ADMIN_SEED_EMAIL=admin@3dmbarete.local
ADMIN_SEED_PASSWORD=admin1234
