# =============================================================================
# Docker + MySQL remota (Hostinger / DO / cualquier MySQL accesible por red)
# =============================================================================
# 1. En la carpeta `back/` ejecutá:
#      copy .env.docker.example .env.docker
#    (PowerShell) o `cp` en Git Bash.
# 2. Editá `.env.docker`: pegá tu DATABASE_URL real, AUTH_SECRET largo, CORS y URL pública del API.
# 3. En Hostinger → MySQL remoto: permití tu IP de casa o `%` para que el contenedor conecte.
# 4. Levantá el API:
#      npm run docker:up
# 5. Probar en el navegador o:
#      curl http://localhost:3056/api/health
# =============================================================================

NODE_ENV=production
PORT=3056
LISTEN_HOST=0.0.0.0

# Ejemplo Hostinger (reemplazá usuario, clave y nombre de BD):
# DATABASE_URL=mysql://USUARIO:CLAVE@srv722.hstgr.io:3306/NOMBRE_BD
DATABASE_URL=mysql://USER:PASSWORD@srv722.hstgr.io:3306/NOMBRE_BD

# Obligatorio con NODE_ENV=production (≥32 caracteres recomendado)
AUTH_SECRET=reemplazar-con-secreto-largo-minimo-32-caracteres-unico

JWT_EXPIRES_SEC=2592000
BCRYPT_SALT_ROUNDS=10

# Orígenes del front (HTTPS en Hostinger). Coma-separados, sin espacios extra.
# Incluí http://localhost:5173 si probás el front en tu PC contra el API en Docker.
CORS_ORIGIN=https://tu-dominio.hostingersite.com,http://localhost:5173

# URL pública donde se sirve ESTE API (imágenes subidas, enlaces en mails).
# En local con Docker: http://localhost:3056
# En DigitalOcean: https://api.tudominio.com
PUBLIC_FILES_BASE_URL=http://localhost:3056

OWNER_EMAIL=tu@email.com
CRON_SECRET=

RESEND_API_KEY=
EMAIL_FROM=3D Mbarete <onboarding@resend.dev>

# Admin inicial (el contenedor ejecuta `prisma db seed` después de migrar; es idempotente).
ADMIN_SEED_EMAIL=admin@3dmbarete.local
ADMIN_SEED_PASSWORD=cambiar-esta-clave-segura

# Si las migraciones las corrés a mano en CI / otro job:
# SKIP_MIGRATIONS=1

# Si no querés ejecutar seed al arrancar (p. ej. ya cargaste datos a mano):
# SKIP_SEED=1

# Puerto del host si 3056 está ocupado: export DOCKER_API_PORT=3057  (Git Bash)
# o en PowerShell: $env:DOCKER_API_PORT=3057
